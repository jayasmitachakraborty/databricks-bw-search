# Copy to `.env` and fill values. Do NOT commit `.env`.

# Databricks Model Serving embedding endpoint name (used by notebooks/rag/create_embeddings.py)
DATABRICKS_EMBEDDING_ENDPOINT=

# Embedding batch size per request (default: 32)
EMBED_BATCH_SIZE=32

# Spark partitions for embedding step (default: 32; more = smaller tasks, less Python OOM)
EMBED_NUM_PARTITIONS=32

# Arrow rows per batch into mapInPandas (default: 500; lower = less RAM per worker)
ARROW_MAX_RECORDS_PER_BATCH=500

# Rows processed per pandas slice inside each batch (default: 2000; lower if OOM persists)
EMBED_PANDAS_MAX_ROWS=2000

# Chunking controls (used by notebooks/rag/chunk_documents.py)
CHUNK_MAX_CHARS=2500
CHUNK_OVERLAP=300

# RAG / retrieval (ai/src/retrieval.py)
#
# Databricks Vector Search index configuration (can also be set in ai/config/vector_index.yml)
DATABRICKS_VECTOR_SEARCH_ENDPOINT_NAME=
DATABRICKS_VECTOR_SEARCH_INDEX_NAME=

# Query understanding (rewrite + metadata filters). If unset, falls back to DATABRICKS_LLM_ENDPOINT.
DATABRICKS_QUERY_UNDERSTANDING_ENDPOINT=

# Default chat model endpoint (used as fallback for query understanding + answering).
DATABRICKS_LLM_ENDPOINT=

# Answer generation endpoint. If unset, falls back to DATABRICKS_LLM_ENDPOINT.
DATABRICKS_ANSWER_ENDPOINT=

# Optional cross-encoder reranker endpoint. If unset, reranking falls back to LLM scoring.
DATABRICKS_RERANK_ENDPOINT=

# Retrieval evaluation gold set (notebooks/rag/evaluate_retrieval.py). EVAL_GOLD_CSV is required there.
EVAL_GOLD_CSV=
EVAL_K=10
EVAL_RELEVANT_THRESHOLD=2
EVAL_SPLIT=
EVAL_RERANK_TOP_K=10
EVAL_OUTPUT_PREDICTIONS_CSV=
EVAL_OUTPUT_JSON=

# Optional: force repo root when running notebooks that load SQL files from disk
# (used by notebooks/transformations/create_semantic_text.py)
REPO_ROOT=
